    "restore:bundle": "node scripts/restore-project.mjs project.bundle.mjs restored-project --force"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
